    {
      "name": "07. Async & Real-time (Layer 4)",
      "description": "Background jobs (ARQ/eager), job progress SSE, transactional outbox relay, parallel dashboard, worker metrics, and the live task WebSocket room.",
      "item": [
        {
          "name": "Enqueue report job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 202', function () {",
                  "  pm.response.to.have.status(202);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.job_id) {",
                  "  pm.collectionVariables.set('job_id', json.job_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"team_id\": 1,\n  \"report_format\": \"summary\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/jobs/reports",
            "description": "Enqueues generate_report and stores job_id. Without REDIS_URL it runs eagerly (status=complete); with Redis it is queued for the ARQ worker."
          }
        },
        {
          "name": "Get job status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/jobs/{{job_id}}",
            "description": "Returns status, progress trail and result for a previously enqueued job."
          }
        },
        {
          "name": "Job progress SSE",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/jobs/{{job_id}}/events",
            "description": "Streams recorded progress steps then a terminal status event."
          }
        },
        {
          "name": "Relay transactional outbox (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/jobs/outbox/relay",
            "description": "Publishes pending outbox events and marks them delivered (idempotent). Requires the admin scope (the bootstrap admin token has it)."
          }
        },
        {
          "name": "Task dashboard (parallel aggregate)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/tasks/dashboard?team_id=1",
            "description": "Status counts + recent titles + activity pulse aggregated via asyncio.gather, each on its own session."
          }
        },
        {
          "name": "Worker & realtime metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}{{api_prefix}}/system/worker-metrics",
            "description": "Active WS connections/rooms, jobs processed/failed, and outbox backlog."
          }
        },
        {
          "name": "WebSocket task room (open as WS request)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ws_url}}{{api_prefix}}/ws/tasks/{{task_id}}?token={{access_token}}",
            "description": "Live task room. In Postman use New > WebSocket Request with this URL. Server sends {type:connected}; send {\"type\":\"ping\"} -> {type:pong} or {\"type\":\"broadcast\",\"text\":\"hi\"}; updating the task over REST pushes a task_event. Token must carry tasks:read."
          }
        }
      ]
    },
    {
      "name": "08. External Integrations",
      "description": "Layer 5 flows: HMAC-protected file uploads, inbound/outbound webhooks, streaming LLM chat, and idempotent Stripe Checkout. External provider requests require the corresponding settings in .env.",
      "item": [
        {
          "name": "Request presigned file upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('file_key', json.key);",
                  "pm.collectionVariables.set('file_content_type', (json.headers && json.headers['Content-Type']) || 'text/plain');",
                  "const uploadUrl = json.upload_url.startsWith('http') ? json.upload_url : pm.collectionVariables.get('base_url') + json.upload_url;",
                  "pm.collectionVariables.set('file_upload_url', uploadUrl);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"postman-report.txt\",\n  \"content_type\": \"text/plain\",\n  \"size\": 28\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/files/presigned-upload",
            "description": "Requests a local HMAC upload token or a real S3/MinIO presigned PUT URL. Requires tasks:write."
          }
        },
        {
          "name": "Upload file bytes",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "{{file_content_type}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "TaskFlow upload from Postman"
            },
            "url": "{{file_upload_url}}",
            "description": "Uses the URL returned by the previous request. Local storage returns TaskFlow JSON; S3 returns the provider response."
          }
        },
        {
          "name": "Confirm file upload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"{{file_key}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/files/confirm"
          }
        },
        {
          "name": "Download file",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/files/download?key={{file_key}}"
          }
        },
        {
          "name": "Receive signed generic webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = JSON.stringify({ id: pm.collectionVariables.get('webhook_id'), type: 'postman.test', data: { source: 'postman' } });",
                  "pm.collectionVariables.set('webhook_body', body);",
                  "const signature = CryptoJS.HmacSHA256(body, pm.collectionVariables.get('webhook_secret')).toString(CryptoJS.enc.Hex);",
                  "pm.collectionVariables.set('webhook_signature', 'sha256=' + signature);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Webhook accepted or deduplicated', function () { pm.expect(['accepted', 'already_processed']).to.include(pm.response.json().status); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": "{{webhook_signature}}"
              },
              {
                "key": "X-Webhook-Id",
                "value": "{{webhook_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhook_body}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/webhooks/generic",
            "description": "Verifies the raw-body HMAC, stores the event idempotently, and enqueues asynchronous processing."
          }
        },
        {
          "name": "Send signed outbound webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"{{webhook_destination}}\",\n  \"event_type\": \"postman.test\",\n  \"provider\": \"generic\",\n  \"payload\": {\n    \"message\": \"hello from TaskFlow\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/webhooks/deliver/test",
            "description": "Queues an admin-only signed outbound delivery. Set webhook_destination to a reachable test receiver before sending."
          }
        },
        {
          "name": "Stream LLM chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Summarize TaskFlow in one sentence\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/llm/chat/stream",
            "description": "Streams Anthropic SSE deltas when ANTHROPIC_API_KEY is set; otherwise returns the deterministic offline fallback."
          }
        },
        {
          "name": "Create Stripe Checkout session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('payment_id', json.id);",
                  "pm.collectionVariables.set('stripe_session_id', json.external_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1999,\n  \"currency\": \"usd\",\n  \"description\": \"TaskFlow Pro\",\n  \"success_url\": \"http://127.0.0.1:3000/billing/success\",\n  \"cancel_url\": \"http://127.0.0.1:3000/billing/cancel\",\n  \"idempotency_key\": \"{{stripe_idempotency_key}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}{{api_prefix}}/payments/checkout",
            "description": "Creates a local pending payment and a Stripe Checkout Session. Requires STRIPE_API_KEY and integrations:write."
          }
        },
        {
          "name": "Get payment status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}{{api_prefix}}/payments/{{payment_id}}",
            "description": "Reads the local payment status; Stripe webhook processing changes it to paid, failed, expired, or refunded."
          }
        }
      ]
    }
  ],
