APP_NAME=TaskFlow API
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./taskflow.db
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=3600
DB_POOL_PRE_PING=true
DB_SEED_ENABLED=true
POSTGRES_DSN=
REDIS_URL=
MONGO_URL=
MONGO_DB_NAME=taskflow
MONGO_EVENTS_COLLECTION=task_events
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=tasks
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
GZIP_MINIMUM_SIZE=1000
DOCS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=10

JWT_SECRET_KEY=dev-insecure-jwt-secret-change-me
JWT_ISSUER=taskflow-api
JWT_AUDIENCE=taskflow-clients
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

CSRF_ENABLED=true
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

MACHINE_API_KEYS=local-dev-key=teams:read,tasks:read,tasks:write,integrations:write

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

SECURE_HEADERS_ENABLED=true
HSTS_ENABLED=true

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_STATE_TTL_SECONDS=600

# Layer 4 — async, background jobs, real-time
# WORKER_EAGER: leave blank to auto-select (eager without REDIS_URL, ARQ-backed with it);
# set true/false to force. Background jobs use ARQ when REDIS_URL is set, else run in-process.
WORKER_QUEUE_NAME=taskflow:jobs
WORKER_EAGER=
WORKER_JOB_TTL_SECONDS=3600
WORKER_MAX_JOBS=20
WORKER_JOB_TIMEOUT_SECONDS=300
OUTBOX_RELAY_BATCH_SIZE=100
SCHEDULER_ENABLED=true
OUTBOX_RELAY_INTERVAL_SECONDS=30
WS_HEARTBEAT_SECONDS=30
WS_SEND_TIMEOUT_SECONDS=5
REALTIME_CHANNEL_PREFIX=taskflow:rt

# Layer 5 — resilient external HTTP
HTTP_CONNECT_TIMEOUT=5
HTTP_READ_TIMEOUT=30
HTTP_WRITE_TIMEOUT=10
HTTP_POOL_TIMEOUT=5
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE=20
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY=0.2
HTTP_RETRY_MAX_DELAY=10
HTTP_RETRY_MAX_AFTER=30
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=30

# Layer 5 — file storage
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./var/storage
STORAGE_URL_SECRET=dev-insecure-storage-secret-change-me
STORAGE_PRESIGN_TTL_SECONDS=300
STORAGE_MAX_UPLOAD_BYTES=52428800
STORAGE_ALLOWED_TYPES=text/plain,text/csv,application/pdf,application/json,image/png,image/jpeg
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=

# Layer 5 — webhooks and email
WEBHOOK_SIGNING_SECRETS=stripe=whsec_dev;github=ghsec_dev;generic=dev-webhook-secret
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_ID_HEADER=X-Webhook-Id
WEBHOOK_DELIVERY_TIMEOUT=10
WEBHOOK_TOLERANCE_SECONDS=300
EMAIL_PROVIDER=generic
EMAIL_PROVIDER_BASE_URL=
EMAIL_API_KEY=
EMAIL_FROM=TaskFlow <no-reply@taskflow.dev>
EMAIL_TIMEOUT_SECONDS=15

# Layer 5 — Stripe and LLM
STRIPE_API_KEY=
STRIPE_BASE_URL=https://api.stripe.com
STRIPE_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_VERSION=2023-06-01
LLM_MAX_TOKENS=1024
LLM_MAX_CONCURRENCY=10
LLM_TIMEOUT_SECONDS=60
