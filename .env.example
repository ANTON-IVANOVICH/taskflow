APP_NAME=TaskFlow API
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./taskflow.db
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=3600
DB_POOL_PRE_PING=true
DB_SEED_ENABLED=true
POSTGRES_DSN=
REDIS_URL=
MONGO_URL=
MONGO_DB_NAME=taskflow
MONGO_EVENTS_COLLECTION=task_events
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=tasks
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
GZIP_MINIMUM_SIZE=1000
DOCS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=10

JWT_SECRET_KEY=dev-insecure-jwt-secret-change-me
JWT_ISSUER=taskflow-api
JWT_AUDIENCE=taskflow-clients
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

CSRF_ENABLED=true
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

MACHINE_API_KEYS=local-dev-key=teams:read,tasks:read,tasks:write,integrations:write

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

SECURE_HEADERS_ENABLED=true
HSTS_ENABLED=true

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_STATE_TTL_SECONDS=600
